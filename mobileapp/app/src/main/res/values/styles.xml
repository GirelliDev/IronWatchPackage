<resources>
    <!-- Base application style -->
    <style name="AppTheme" parent="Theme.IronWatchMobile">
        <!-- Customize default text appearances -->
        <item name="android:textColor">@color/md_theme_onBackground</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/roboto</item>
    </style>

    <!-- Button style -->
    <style name="AppButton" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/md_theme_primary</item>
        <item name="android:textColor">@color/md_theme_onPrimary</item>
    </style>

    <!-- Card style -->
    <style name="AppCard" parent="Widget.Material3.CardView">
        <item name="cardBackgroundColor">@color/md_theme_surface</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
    </style>
</resources>
